<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="fleetflow_maintenance_view_form" model="ir.ui.view">
        <field name="name">fleet.flow.maintenance.form</field>
        <field name="model">fleet.flow.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="action_start" string="Start Service"
                        type="object" class="btn-primary"
                        invisible="state != 'planned'"
                        groups="fleetflow.fleetflow_group_fleet_manager"/>
                    <button name="action_complete" string="Mark Complete"
                        type="object" class="btn-success"
                        invisible="state != 'in_progress'"
                        groups="fleetflow.fleetflow_group_fleet_manager"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="planned,in_progress,completed"/>
                </header>
                <sheet>
                    <group col="2">
                        <group string="Service Info">
                            <field name="vehicle_id"/>
                            <field name="service_type"/>
                            <field name="date"/>
                            <field name="mechanic"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="page_notes">
                            <field name="notes" nolabel="1"
                                placeholder="Service details and observations"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="fleetflow_maintenance_view_list" model="ir.ui.view">
        <field name="name">fleet.flow.maintenance.list</field>
        <field name="model">fleet.flow.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance Logs" sample="1"
                decoration-info="state == 'planned'"
                decoration-warning="state == 'in_progress'"
                decoration-success="state == 'completed'">
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="description"/>
                <field name="mechanic" optional="show"/>
                <field name="cost"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'planned'"
                    decoration-warning="state == 'in_progress'"
                    decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="fleetflow_maintenance_view_search" model="ir.ui.view">
        <field name="name">fleet.flow.maintenance.search</field>
        <field name="model">fleet.flow.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="mechanic"/>
                <filter string="Planned" name="planned" domain="[('state', '=', 'planned')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group>
                    <filter string="Vehicle" name="groupby_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Service Type" name="groupby_service_type" context="{'group_by': 'service_type'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="groupby_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="fleetflow_maintenance_action" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">fleet.flow.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first vehicle service!
            </p>
            <p>Track preventive and reactive maintenance for your fleet.</p>
        </field>
    </record>

</odoo>

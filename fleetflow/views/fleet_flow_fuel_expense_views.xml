<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="fleetflow_fuel_expense_view_form" model="ir.ui.view">
        <field name="name">fleet.flow.fuel.expense.form</field>
        <field name="model">fleet.flow.fuel.expense</field>
        <field name="arch" type="xml">
            <form string="Fuel &amp; Expense">
                <sheet>
                    <group col="2">
                        <group string="Expense Details">
                            <field name="vehicle_id"/>
                            <field name="trip_id" domain="[('vehicle_id', '=', vehicle_id)]"/>
                            <field name="expense_type"/>
                            <field name="date"/>
                        </group>
                        <group string="Amount">
                            <field name="amount"/>
                            <field name="liters" invisible="expense_type != 'fuel'"/>
                            <field name="odometer_at_fill" invisible="expense_type != 'fuel'"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fleetflow_fuel_expense_view_list" model="ir.ui.view">
        <field name="name">fleet.flow.fuel.expense.list</field>
        <field name="model">fleet.flow.fuel.expense</field>
        <field name="arch" type="xml">
            <list string="Fuel &amp; Expenses" sample="1">
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="trip_id" optional="show"/>
                <field name="expense_type"/>
                <field name="amount" sum="Total Amount"/>
                <field name="liters" optional="show" sum="Total Liters"/>
                <field name="odometer_at_fill" optional="hide"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="fleetflow_fuel_expense_view_search" model="ir.ui.view">
        <field name="name">fleet.flow.fuel.expense.search</field>
        <field name="model">fleet.flow.fuel.expense</field>
        <field name="arch" type="xml">
            <search string="Search Fuel &amp; Expenses">
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <field name="expense_type"/>
                <filter string="Fuel" name="fuel" domain="[('expense_type', '=', 'fuel')]"/>
                <filter string="Toll" name="toll" domain="[('expense_type', '=', 'toll')]"/>
                <filter string="Parking" name="parking" domain="[('expense_type', '=', 'parking')]"/>
                <filter string="Other" name="other" domain="[('expense_type', '=', 'other')]"/>
                <separator/>
                <filter name="filter_date" string="Date" date="date" default_period="month"/>
                <group>
                    <filter string="Vehicle" name="groupby_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Expense Type" name="groupby_type" context="{'group_by': 'expense_type'}"/>
                    <filter string="Trip" name="groupby_trip" context="{'group_by': 'trip_id'}"/>
                    <filter string="Month" name="groupby_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="fleetflow_fuel_expense_action" model="ir.actions.act_window">
        <field name="name">Fuel &amp; Expenses</field>
        <field name="res_model">fleet.flow.fuel.expense</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first fuel or expense entry!
            </p>
            <p>Track fuel costs, tolls, parking, and other expenses per vehicle and trip.</p>
        </field>
    </record>

</odoo>
